{
  "name": "kport_ssh-sftp-client",
  "version": "0.1.0",
  "private": true,
  "productName": "KPort",
  "author": "huukhuong",
  "description": "A cross-platform SSH & SFTP client for developers",
  "homepage": "https://github.com/huukhuong/KPort_SSH-SFTP-Client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huukhuong/KPort_SSH-SFTP-Client.git"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "prepare:electron-shell": "node scripts/prepare-electron-shell.js",
    "build": "electron-vite build",
    "dist": "yarn build && electron-builder",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:win": "yarn build && electron-builder --win",
    "dist:linux": "yarn build && electron-builder --linux",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "generate:icons": "node scripts/generate-app-icon.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@mantine/notifications": "^7.17.0",
    "@monaco-editor/react": "^4.7.0",
    "@tabler/icons-react": "^3.31.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-material-icon-theme": "^1.0.4",
    "ssh2": "^1.17.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.3",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
